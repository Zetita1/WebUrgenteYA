# ══════════════════════════════════════════════════════
#  PRODUCCIÓN — Copia esto como .env en el servidor VPS
#  NUNCA subas este archivo con valores reales a GitHub
# ══════════════════════════════════════════════════════

PORT=3001
NODE_ENV=production

# ── JWT — GENERA UNO NUEVO CON ESTE COMANDO: ──────────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZA_CON_64_BYTES_ALEATORIOS_AQUI
JWT_EXPIRES_IN=7d

# ── Admin ─────────────────────────────────────────────
ADMIN_EMAIL=admin@urgenteya.cl
# Usa una contraseña fuerte (min 12 chars, mayus, numeros, simbolos)
ADMIN_PASSWORD=REEMPLAZA_CON_CONTRASENA_FUERTE

# ── Gmail (contraseña de aplicación, NO tu contraseña normal) ──
# Activa 2FA → myaccount.google.com/apppasswords → crea "UrgenteYa"
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=REEMPLAZA_CON_APP_PASSWORD
ADMIN_NOTIFY_EMAIL=tu_correo@gmail.com

# ── URLs ──────────────────────────────────────────────
SITE_URL=https://urgenteya.cl
FRONTEND_URL=https://urgenteya.cl

# ── WhatsApp admin ────────────────────────────────────
ADMIN_WHATSAPP=56XXXXXXXXX
